#!/usr/bin/env bash
set -euo pipefail

OS="{{ .chezmoi.os }}"
BREW_PREFIX="$HOME/.linuxbrew"

echo "[chezmoi] Installing base tools for ${OS}..."

if [[ "$OS" == "darwin" ]]; then
  if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew is not installed. Install Homebrew first, then re-run: chezmoi apply"
    exit 1
  fi

  brew update
  brew install git chezmoi || true
fi

if [[ "$OS" == "linux" ]]; then
  if command -v apt >/dev/null 2>&1; then
    sudo apt update
    sudo apt install -y \
      curl \
      git \
      ca-certificates \
      build-essential \
      procps \
      file \
      zsh \
      fzf \
      direnv \
      bat \
      fd-find \
      ripgrep \
      jq \
      unzip
  else
    echo "No apt found. Skipping system package installation."
  fi

  if [[ ! -x "$BREW_PREFIX/bin/brew" ]]; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" -- -b "$BREW_PREFIX"
  fi

  if [[ -x "$BREW_PREFIX/bin/brew" ]]; then
    eval "$("$BREW_PREFIX/bin/brew" shellenv)"
  else
    echo "Homebrew was not installed at $BREW_PREFIX."
    exit 1
  fi
fi
