# Base PATH.
export PATH="$HOME/bin:/usr/local/bin:$PATH"

# WakaTime shell tracking without depending on Oh My Zsh.
export ZSH_WAKATIME_BIN=/opt/homebrew/bin/wakatime-cli

_wakatime_heartbeat() {
  (( WAKATIME_DO_NOT_TRACK )) && return

  local wakatime_bin="${ZSH_WAKATIME_BIN:-$HOME/.wakatime/wakatime-cli}"
  [[ -x "$wakatime_bin" ]] || return

  local last_command="${1%% *}"
  local root_directory

  if [[ -f .wakatime-project ]]; then
    IFS= read -r root_directory < .wakatime-project
  fi

  if [[ -z "$root_directory" ]]; then
    root_directory="$(git rev-parse --show-toplevel 2>/dev/null)" || root_directory="Terminal"
  fi

  local offline_args=()
  (( WAKATIME_DISABLE_OFFLINE )) && offline_args=(--disable-offline)

  "$wakatime_bin" --write \
    --plugin "zsh/1.0.0" \
    --entity-type app \
    --entity "$last_command" \
    --project "${root_directory:t}" \
    --language sh \
    --timeout "${WAKATIME_TIMEOUT:-5}" \
    "${offline_args[@]}" \
    &>/dev/null </dev/null &!
}

autoload -Uz add-zsh-hook
add-zsh-hook preexec _wakatime_heartbeat

