  blue = '#1e66f5',
  mauve = '#8839ef',
  green = '#40a02b',
  yellow = '#df8e1d',
}

-- tabline.wez already inserts one space after icons; Nerd Font glyphs still
-- look visually tight, so use an extra trailing space for icon-bearing items.
local function spaced_icon(icon)
  return icon .. ' '
end


