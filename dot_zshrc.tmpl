# Personal aliases can be placed here.
# Created by `pipx` on 2023-12-24 17:57:46
if [[ ! -o login ]] && command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

path_prepend "$HOME/Library/Android/sdk/platform-tools"
path_prepend "$HOME/Android/Sdk/platform-tools"
path_prepend "$HOME/.lmstudio/bin"

{{ if eq .chezmoi.os "darwin" }}
if command -v /usr/libexec/java_home >/dev/null 2>&1; then
  java_home="$(/usr/libexec/java_home -v 24 2>/dev/null || true)"
  [[ -n "$java_home" ]] && export JAVA_HOME="$java_home"
fi
{{ end }}

# History updates
# https://zsh.sourceforge.io/Doc/Release/Options.html#index-HISTIGNOREALLDUPS
setopt share_history
setopt hist_ignore_all_dups
setopt hist_ignore_space

# bun completions
[[ -r "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
path_prepend "$BUN_INSTALL/bin"

[[ -d "$HOME/.zfunc" ]] && fpath+=~/.zfunc
autoload -Uz compinit
compinit

if command -v jj >/dev/null 2>&1; then
  source <(COMPLETE=zsh jj)
fi

autoload -U +X bashcompinit && bashcompinit
if command -v terraform >/dev/null 2>&1; then
  complete -o nospace -C "$(command -v terraform)" terraform
fi

# Added by Antigravity
export EDITOR=nvim
export VISUAL=nvim

if command -v op >/dev/null 2>&1; then
  eval "$(op completion zsh)"
  compdef _op op
fi

# Starship prompt.
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi
