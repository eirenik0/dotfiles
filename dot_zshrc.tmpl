# Base PATH.
path_prepend() {
  [[ -d "$1" ]] || return

  case ":$PATH:" in
    *":$1:"*) ;;
    *) PATH="$1:$PATH" ;;
  esac
}

path_prepend "$HOME/bin"
path_prepend "$HOME/.local/bin"
path_prepend "/usr/local/bin"

brew_bin=""
for candidate in \
  "$(command -v brew 2>/dev/null)" \
  /opt/homebrew/bin/brew \
  /usr/local/bin/brew \
  /home/linuxbrew/.linuxbrew/bin/brew \
  "$HOME/.linuxbrew/bin/brew"
do
  if [[ -n "$candidate" && -x "$candidate" ]]; then
    brew_bin="$candidate"
    break
  fi
done

if [[ -n "$brew_bin" ]]; then
  eval "$("$brew_bin" shellenv)"
fi

# WakaTime shell tracking without depending on Oh My Zsh.
if command -v wakatime-cli >/dev/null 2>&1; then
  export ZSH_WAKATIME_BIN="$(command -v wakatime-cli)"
elif [[ -x "$HOME/.wakatime/wakatime-cli" ]]; then
  export ZSH_WAKATIME_BIN="$HOME/.wakatime/wakatime-cli"
fi

_wakatime_heartbeat() {
  (( WAKATIME_DO_NOT_TRACK )) && return

  local wakatime_bin="${ZSH_WAKATIME_BIN:-$HOME/.wakatime/wakatime-cli}"
  [[ -x "$wakatime_bin" ]] || return

  local last_command="${1%% *}"
  local root_directory

  if [[ -f .wakatime-project ]]; then
    IFS= read -r root_directory < .wakatime-project
  fi

  if [[ -z "$root_directory" ]]; then
    root_directory="$(git rev-parse --show-toplevel 2>/dev/null)" || root_directory="Terminal"
  fi

  local offline_args=()
  (( WAKATIME_DISABLE_OFFLINE )) && offline_args=(--disable-offline)

  "$wakatime_bin" --write \
    --plugin "zsh/1.0.0" \
    --entity-type app \
    --entity "$last_command" \
    --project "${root_directory:t}" \
    --language sh \
    --timeout "${WAKATIME_TIMEOUT:-5}" \
    "${offline_args[@]}" \
    &>/dev/null </dev/null &!
}

autoload -Uz add-zsh-hook
add-zsh-hook preexec _wakatime_heartbeat

